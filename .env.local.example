# Resend API key (https://resend.com/api-keys) — server-only, used by app/api/contact/route.ts.
# Never prefix this with NEXT_PUBLIC_; it must not reach the client bundle.
RESEND_API_KEY=your-resend-api-key-here
# Verified Resend sender, e.g. "Portfolio Contact Form <contact@serhiikholodnyi.com>".
# Defaults to onboarding@resend.dev (Resend's shared testing domain) if unset.
RESEND_FROM_EMAIL=Portfolio Contact Form <onboarding@resend.dev>
# Absolute site URL used for SEO canonical/sitemap, e.g. https://serhiikholodnyi.com
NEXT_PUBLIC_SITE_URL=https://example.com
